# Cribl Cloud API Credentials
# Get these from Cribl Cloud > Settings > API Credentials
CRIBL_CLIENT_ID=your-client-id
CRIBL_CLIENT_SECRET=your-client-secret
CRIBL_ORGANIZATION_ID=your-organization-id

# Worker Group Configuration (optional - defaults provided)
WORKER_GROUP_ID=quickstart-wg
WORKER_GROUP_NAME=Quickstart Worker Group
WORKER_GROUP_DESCRIPTION=Worker group created via Python SDK quickstart

# Pack Configuration (optional - defaults to AWS VPC Flow Logs)
PACK_ID=cribl-aws-vpcflow-logs
PACK_SOURCE=https://github.com/criblpacks/cribl-aws-vpcflow-logs
