# Copy this file to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored to protect your credentials

cribl_client_id     = "your-client-id"
cribl_client_secret = "your-client-secret"
cribl_cloud_org     = "your-organization-id"

# Optional: customize these values
# worker_group_name        = "my-worker-group"
# worker_group_id          = "my-wg"
# worker_group_description = "My worker group"
# pack_source              = "git+https://github.com/criblpacks/cribl-palo-alto-networks.git"
# pack_id                  = "cribl-palo-alto-networks"
